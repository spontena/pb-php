{
    "name": "spontena/pb-php",
    "description": "Pandorabots API client for PHP",
    "keywords": ["pandorabots", "php", "aiml", "spontena"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "knlab",
            "email": "35491752+knlab@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Spontena\\PbPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spontena\\PbPhp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "phpstan analyse src --level=6"
    }
}
